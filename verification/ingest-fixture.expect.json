{
  "name": "ingest acceptance",
  "checks": [
    {
      "id": "source_page_created",
      "description": "Source page created",
      "type": "contains_all",
      "file": "verification/ingest-fixture.md",
      "patterns": ["## Summary", "## Key Claims", "## Entities Mentioned", "## Concepts Mentioned"]
    },
    {
      "id": "index_updated",
      "description": "Index updated",
      "type": "contains",
      "file": "verification/README.md",
      "pattern": "Index updated"
    },
    {
      "id": "log_appended",
      "description": "Log appended",
      "type": "contains",
      "file": "verification/README.md",
      "pattern": "Log appended"
    },
    {
      "id": "raw_untouched",
      "description": "Raw source remains immutable",
      "type": "contains",
      "file": "verification/README.md",
      "pattern": "Raw stays untouched"
    }
  ]
}
